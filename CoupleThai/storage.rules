rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isSmallEnough() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    match /couples/{coupleId}/memories/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && isImage()
        && isSmallEnough()
        && request.resource.metadata.coupleId == coupleId
        && request.resource.metadata.uploaderId == request.auth.uid
        && request.resource.metadata.uploaderName is string;
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
